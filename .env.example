# ------------------------------------------------------------------------------
# securitycam - Example environment configuration
# ------------------------------------------------------------------------------
# Copy this file to `.env` in the project root and adapt values to your setup.
# This file is safe to commit as long as it contains placeholder values only.
# Never commit real camera credentials or production secrets.
# ------------------------------------------------------------------------------

# ------------------------------------------------------------------------------
# Camera / RTSP source
# ------------------------------------------------------------------------------
# Optional multi-camera definition.
# Format:
# SECURITYCAM_CAMERAS=id|Label|ip-or-host|username|password|stream-path;id2|Label 2|ip2|username2|password2|stream2
# When set, this overrides the single-camera values below.
SECURITYCAM_CAMERAS=

# IP or DNS name of your camera in the local network.
SECURITYCAM_CAMERA_IP=192.168.1.100

# Camera account used for RTSP authentication.
SECURITYCAM_CAMERA_USERNAME=change-me

# Camera password used for RTSP authentication.
SECURITYCAM_CAMERA_PASSWORD=change-me

# Camera stream path. Typical values:
# - stream1 = higher quality / higher bandwidth
# - stream2 = lower quality / lower bandwidth
SECURITYCAM_CAMERA_STREAM_PATH=stream1

# ------------------------------------------------------------------------------
# Web application runtime
# ------------------------------------------------------------------------------
# Bind address for Flask app. Use 127.0.0.1 for local-only access.
SECURITYCAM_APP_HOST=0.0.0.0

# TCP port for HTTP server.
SECURITYCAM_APP_PORT=5000

# Debug mode should stay false except local debugging sessions.
SECURITYCAM_APP_DEBUG=false

# Flask secret key for cookies/signing.
# Use a long random value in real environments.
SECURITYCAM_SECRET_KEY=change-me

# ------------------------------------------------------------------------------
# Session / HTTP security
# ------------------------------------------------------------------------------
# Set true only when traffic is served via HTTPS/TLS.
SECURITYCAM_SESSION_COOKIE_SECURE=false

# Recommended values: Lax (balanced) or Strict (stronger CSRF protection).
SECURITYCAM_SESSION_COOKIE_SAMESITE=Lax

# Optional comma-separated allow-list for Host headers, e.g.:
# localhost,127.0.0.1,cam.example.internal
# Leave empty to disable host restriction.
SECURITYCAM_TRUSTED_HOSTS=

# ------------------------------------------------------------------------------
# AI model selection
# ------------------------------------------------------------------------------
# Startup model name. Must be one of config.AVAILABLE_MODELS.
SECURITYCAM_YOLO_MODEL=yolov8n.pt

# ------------------------------------------------------------------------------
# Performance tuning
# ------------------------------------------------------------------------------
# Resize factor for outgoing stream (0.2..1.0).
# Lower values reduce CPU usage and bandwidth.
SECURITYCAM_DISPLAY_SCALE=1.0

# JPEG quality for MJPEG output (30..95).
# Higher value = better quality, more bandwidth.
SECURITYCAM_JPEG_QUALITY=85

# Run face detection only every N frames.
SECURITYCAM_FACE_DETECT_EVERY=5

# Internal scale for face detection (0.2..1.0).
# Lower value = faster, less precise.
SECURITYCAM_FACE_DETECT_SCALE=0.5

# Temporal smoothing for box coordinates (0.0..1.0).
# Higher value = smoother overlay, more lag.
SECURITYCAM_SMOOTH_ALPHA=0.6

# Run hand detection only every N frames (MediaPipe Hands).
SECURITYCAM_HAND_DETECT_EVERY=5

# Internal scale for hand detection (0.2..1.0).
SECURITYCAM_HAND_DETECT_SCALE=0.5

# YOLO image size (320..1280).
# Higher value = better detection detail, slower inference.
SECURITYCAM_YOLO_IMG_SIZE=640

# Optional auto-install for missing torch/ultralytics.
# Recommended: false in controlled environments.
SECURITYCAM_AUTO_INSTALL_DEPS=false

# PyTorch index URL used only when auto-install is enabled.
SECURITYCAM_TORCH_CUDA_INDEX_URL=https://download.pytorch.org/whl/nightly/cu128
